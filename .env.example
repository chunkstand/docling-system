DOCLING_SYSTEM_ENV=development
DOCLING_SYSTEM_DATABASE_URL=postgresql+psycopg://docling:docling@localhost:5432/docling_system
DOCLING_SYSTEM_STORAGE_ROOT=./storage
DOCLING_SYSTEM_OPENAI_API_KEY=
DOCLING_SYSTEM_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DOCLING_SYSTEM_EMBEDDING_DIM=1536
DOCLING_SYSTEM_WORKER_POLL_SECONDS=2
DOCLING_SYSTEM_WORKER_LEASE_TIMEOUT_SECONDS=300
DOCLING_SYSTEM_WORKER_MAX_ATTEMPTS=3
DOCLING_SYSTEM_WORKER_HEARTBEAT_SECONDS=30
DOCLING_SYSTEM_LOCAL_INGEST_ALLOWED_ROOTS=
DOCLING_SYSTEM_LOCAL_INGEST_MAX_FILE_BYTES=104857600
DOCLING_SYSTEM_LOCAL_INGEST_MAX_PAGES=750
